# Aplicacion
NODE_ENV=production
PORT=5000
DATABASE_URL=postgresql://usuario:password@postgres:5432/sistema_migratorio
SECRET_KEY=reemplazar-con-un-secreto-de-al-menos-32-caracteres
FRONTEND_ORIGINS=https://tu-dominio.example

# Cifrado por oficina: 32 bytes en base64 o 64 caracteres hex
CREDENTIAL_ENCRYPTION_KEY=reemplazar-con-32-bytes-en-base64

# WasenderAPI
WASENDER_API_BASE_URL=https://www.wasenderapi.com
# Respaldo opcional; se recomienda un secreto distinto por oficina desde la interfaz.
WASENDER_WEBHOOK_SECRET=
WEBHOOK_WORKER_ENABLED=true
WEBHOOK_WORKER_INTERVAL_MS=1000
WEBHOOK_WORKER_BATCH_SIZE=20
OUTBOUND_WORKER_ENABLED=true
OUTBOUND_WORKER_INTERVAL_MS=1000

# Interruptor global. Mantener false durante las Fases 1 y 2.
AGENT_AUTOMATION_ENABLED=false
AGENT_WORKER_ENABLED=true
AGENT_WORKER_INTERVAL_MS=1500

# OpenAI Responses API (solo se usa cuando la automatización global y la oficina están habilitadas)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-luna
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MAX_OUTPUT_TOKENS=900
ENGAGEMENT_WORKER_ENABLED=true
ENGAGEMENT_WORKER_INTERVAL_MS=30000
WEBHOOK_PAYLOAD_RETENTION_DAYS=30
REACTIVATION_DAILY_OFFICE_LIMIT=200
